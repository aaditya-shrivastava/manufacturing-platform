FROM python:3.11-slim

# Prevents .pyc files and enables real-time logs
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app

# Install system dependency for healthcheck
RUN apt-get update && apt-get install -y --no-install-recommends curl && \
    rm -rf /var/lib/apt/lists/*

# Install root shared deps first (layer cache friendly)
COPY Shared-root-files/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Install app-specific deps
COPY multi-agent-manufacturing/requirements.txt ./multi-agent-manufacturing/requirements.txt
RUN pip install --no-cache-dir -r multi-agent-manufacturing/requirements.txt

# Copy only this app's source
COPY multi-agent-manufacturing/ ./multi-agent-manufacturing/

EXPOSE 8501

HEALTHCHECK --interval=30s --timeout=10s --start-period=15s --retries=3 \
    CMD curl -f http://localhost:8501/_stcore/health || exit 1

CMD ["streamlit", "run", "multi-agent-manufacturing/app.py", \
     "--server.port=8501", \
     "--server.address=0.0.0.0", \
     "--server.headless=true"]
